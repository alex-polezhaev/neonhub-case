# ---- Site ----
# Public base URL of the storefront (no trailing slash). Used by metadata,
# canonical URLs, sitemap, robots, JSON-LD and the marketing feeds.
NEXT_PUBLIC_SITE_URL=https://neonhub.example

# ---- Order intake ----
# Webhook that receives quick-order / cart submissions from the client.
NEXT_PUBLIC_ORDER_WEBHOOK_URL=https://webhook.example/orders

# ---- Catalog source (build-time) ----
# Endpoint the scripts/fetch-products.mjs pipeline pulls the catalog from.
PRODUCTS_API_URL=https://cms.example/api/products

# ---- Analytics (optional; scripts only injected when set) ----
NEXT_PUBLIC_YANDEX_METRIKA_ID=
NEXT_PUBLIC_VK_PIXEL_ID=
NEXT_PUBLIC_PINTEREST_VERIFY=

# ---- IndexNow (search-engine instant indexing) ----
INDEXNOW_KEY=your-indexnow-key
INDEXNOW_HOST=neonhub.example

# ---- Deploy (deploy.sh, key-based SSH only) ----
SSH_HOST=user-host.example.com
SSH_USER=deploy-user
DEPLOY_PATH=~/public_html/
SSH_PORT=22
