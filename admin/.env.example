# ---------------------------------------------------------------------------
# NeonHub Admin — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# n8n instance that hosts the content webhooks (ideas / prompts / tasks /
# products / variants / videos / video-compilations). Base host only, no
# trailing slash — the app appends the "/webhook/..." paths itself.
# Used server-side by the route handlers under app/api/*.
N8N_BASE_URL=https://n8n.example.com

# Job server that accepts batch image-generation jobs (POST /create-job).
# This is the external system that submits 50-row batches to the Gemini
# "Nano Banana" Batch API. Server-side value (preferred).
JOB_SERVER_URL=http://job-server.example.com:3001

# Same job server, exposed to the browser if a client component ever needs it.
# Optional — the server route falls back to JOB_SERVER_URL.
NEXT_PUBLIC_JOB_SERVER_URL=http://job-server.example.com:3001

# Directus instance that stores rendered video assets. Used to rewrite proxied
# video URLs to their public /assets/ form.
NEXT_PUBLIC_DIRECTUS_URL=https://directus.example.com

# Password for the thin client-side demo gate (see lib/auth.ts). This is NOT
# real authentication — it only hides the UI behind a shared password.
NEXT_PUBLIC_ADMIN_PASSWORD=change-me

# Optional: override the n8n webhook for video compilations (has a sensible
# default fallback in app/api/video-compilations/route.ts).
# N8N_VIDEO_COMPILATIONS_WEBHOOK_URL=
