# Directus (file storage) — used by directus.js to upload the annotated visualization.
# The core computer-vision analysis works WITHOUT any of these.
DIRECTUS_URL=https://directus.example.com
DIRECTUS_TOKEN=your-directus-static-token
DIRECTUS_FOLDER_ID=00000000-0000-0000-0000-000000000000

# n8n webhook that persists the computed sizes (used by POST /proxy/save-sizes). Optional.
N8N_SAVE_SIZES_URL=https://n8n.example.com/webhook/neon/save_sizes_json

# HTTP port (optional, default 2999)
PORT=2999
