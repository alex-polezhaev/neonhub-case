# Directus (file storage) — used by api/upload.js (uploads) and api/proxy.js (CORS image proxy allow-list).
DIRECTUS_URL=https://directus.example.com
DIRECTUS_TOKEN=your-directus-static-token
DIRECTUS_FOLDER_ID=00000000-0000-0000-0000-000000000000

# n8n webhook that receives the saved threshold / sizes JSON (used by api/n8n-send.js).
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/neon/save_sizes_json
